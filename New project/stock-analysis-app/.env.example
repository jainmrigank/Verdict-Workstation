# Optional: set this when the market-data bridge is exposed through a public HTTPS
# URL or a LAN URL that differs from the current browser host.
# Example: VITE_MARKET_DATA_BASE_URL=https://your-bridge-url
VITE_MARKET_DATA_BASE_URL=

# Private-group bridge protection. Set these only on the bridge machine, never
# as VITE_ variables. Remote origins fail closed when no group code is set.
# BRIDGE_GROUP_ACCESS_CODE=choose-a-long-shared-code
# BRIDGE_TOKEN_SECRET=generate-a-long-random-signing-secret
# BRIDGE_TOKEN_TTL_SECONDS=43200
# BRIDGE_RATE_LIMIT_PER_MINUTE=90
# BRIDGE_SESSION_ATTEMPTS_PER_MINUTE=10
# MARKET_DATA_ALLOW_ORIGIN=https://your-frontend.example

# Grounded analyst secrets stay on the Python market-data bridge. Put these in
# ../.env or in the shell that starts scripts/market_data_server.py, never in VITE_ variables.
# LLM_PROVIDER=gemini
# LLM_API_KEY=...
# LLM_MODEL=gemini-3.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_API_KEY=... # May replace LLM_API_KEY and also powers embeddings/dataset work.
# GEMINI_DATASET_MODEL=gemini-3.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# Vertex tuned-model inference alternative:
# LLM_PROVIDER=vertex
# LLM_MODEL=stock-analysis-agent-v1
# VERTEX_SOURCE_MODEL=gemini-2.5-flash
# VERTEX_TUNED_MODEL_URL=https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT/locations/LOCATION/endpoints/ENDPOINT:generateContent
# VERTEX_ACCESS_TOKEN=... # Optional; otherwise Application Default Credentials are used through gcloud.
