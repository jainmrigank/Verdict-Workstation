{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stock-analysis-agent.local/schemas/training-example.v1.json",
  "title": "ProviderNeutralTrainingExampleV1",
  "type": "object",
  "required": ["id", "lineageId", "split", "messages", "metadata"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "lineageId": { "type": "string", "minLength": 1 },
    "split": { "enum": ["train", "validation", "eval"] },
    "messages": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/message" },
        { "$ref": "#/$defs/message" },
        { "$ref": "#/$defs/message" }
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "message": {
      "type": "object",
      "required": ["role", "content"],
      "properties": {
        "role": { "enum": ["system", "user", "assistant"] },
        "content": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
