# Copy this file to .env and fill values locally.
# Do not paste API secrets in chat.

KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_USER_ID=

# Optional sharing setup.
# Frontend: when using a public HTTPS tunnel for the data bridge, set this before running Vite.
VITE_MARKET_DATA_BASE_URL=

# Data bridge: comma-separated public frontend origins allowed to call scripts/market_data_server.py.
MARKET_DATA_ALLOW_ORIGIN=
